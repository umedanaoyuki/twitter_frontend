{
  "name": "twitter_frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "openapi:sync": "cp ../golang_twitter/docs/swagger.json ./openapi/swagger.json",
    "openapi:convert": "swagger2openapi ./openapi/swagger.json -o ./openapi/openapi.json",
    "openapi:generate": "openapi-typescript ./openapi/openapi.json -o ./lib/api/schema.d.ts",
    "openapi:update": "npm run openapi:sync && npm run openapi:convert && npm run openapi:generate"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@hugeicons/core-free-icons": "^4.1.4",
    "@hugeicons/react": "^1.1.6",
    "@next-safe-action/adapter-react-hook-form": "^2.0.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "16.2.6",
    "next-safe-action": "^8.5.3",
    "next-themes": "^0.4.6",
    "openapi-fetch": "^0.17.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.0",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "openapi-typescript": "^7.13.0",
    "prettier": "3.8.3",
    "swagger2openapi": "^7.0.8",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
